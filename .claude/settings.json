{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File .claude/check-docs.ps1",
            "timeout": 15,
            "statusMessage": "Verification documentation avant push..."
          }
        ]
      }
    ]
  }
}
